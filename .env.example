# Django Secret Key (auto-generated if not set)
# Used for cryptographic signing. Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Debug mode (default: false)
# Set to 'true' or '1' to enable debug toolbar and verbose errors
DJANGO_DEBUG=

# Allowed hosts (default: localhost,127.0.0.1)
# Comma-separated list of hostnames
DJANGO_ALLOWED_HOSTS=

# CORS allowed origins (default: localhost:5173,localhost:5174)
# Comma-separated list of full origins (e.g. https://myapp.com)
DJANGO_CORS_ORIGINS=
